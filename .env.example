# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_ENCRYPTION_KEY=

OPENAI_API_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
# Cron jobs bypass RLS and need the service role key
SUPABASE_SERVICE_ROLE_KEY=
# Found in Supabase dashboard → Settings → API → JWT Secret. Used by the
# OAuth callback to mint Supabase-compatible JWTs and set sb-* cookies so
# RLS-protected reads work via @supabase/ssr.
SUPABASE_JWT_SECRET=

RESEND_API_KEY=
# Optional — overrides the default From address (noreply@autoplier.com) used for digest and failure emails
RESEND_FROM_ADDRESS=

# Google OAuth app — create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# e.g. https://yourapp.com/api/auth/google/callback (must match Google Cloud Console)
GOOGLE_REDIRECT_URI=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=

# Canonical app URL (no trailing slash). When set, Stripe Checkout's success_url
# and cancel_url use this instead of the inbound request's origin — keeps post-
# checkout redirects on the host Vercel actually serves (avoids apex→www flips
# that can drop session cookies). e.g. https://www.autoplier.com
NEXT_PUBLIC_APP_URL=
